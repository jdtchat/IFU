              if ($(this).parent().hasClass("active") === false) {
                $(".cherito-accordion." + accordionName)
                  .find(".accordion")
                  .removeClass("active");
                $(".cherito-accordion." + accordionName)
                  .find(".accordion")
                  .find(".accordion-content")
                  .slideUp();
                $(this).parent().addClass("active");
                $(this).parent().find(".accordion-content").slideDown();
              }
            });
        });
      });
    }
  };


  //elementor front start
  $(window).on("elementor/frontend/init", function () {
    elementorFrontend.hooks.addAction(
      "frontend/element_ready/widget",
      WidgetDefaultHandler
    );

    elementorFrontend.hooks.addAction(
      "frontend/element_ready/cherito-faq.default",
      WidgetFaqHandler
    );

  });

  // login
  $("#cherito-login").submit(function (event) {
    event.preventDefault();

    var login = "action=signup_paragon&param=login&" + $(this).serialize();
    var loginResult = $(".login-result");
    $.ajax({
      type: "POST",
      url: cherito_login_object.ajaxurl,
      data: login,
      beforeSend: function () {
        // setting a timeout
        loginResult.addClass("loading");
      },
      success: function (data) {
        loginResult.removeClass("loading");
        if (data.status == 2) {
          loginResult.removeClass("alert alert-warning");
          loginResult.html(data.message).addClass("alert alert-success");
          window.location.href = cherito_login_object.login_redirect_url;
        } else if (data.status == 1) {
          loginResult.html(data.message).addClass("alert alert-warning");
        } else {
          loginResult
            .html(cherito_login_object.message)
            .addClass("alert alert-warning");
        }
      }
    });
  }); //end login

  // register
  $("#cherito-registration").submit(function (event) {
    event.preventDefault();

    var signupForm =
      "action=signup_paragon&param=register&" + $(this).serialize();
    var registerationResult = $(".registration-result");
    $.ajax({
      type: "POST",
      url: cherito_login_object.ajaxurl,
      data: signupForm,
      beforeSend: function () {
        // setting a timeout
        registerationResult.addClass("loading");
      },
      success: function (data) {
        registerationResult.removeClass("loading");
        if (data.status == 2) {
          registerationResult.removeClass("alert alert-warning");
          registerationResult
            .html(data.message)
            .addClass("alert alert-success");
          window.location.href = cherito_login_object.registration_redirect_url;
        } else {
          registerationResult
            .html(data.message)
            .addClass("alert alert-warning");
        }
      }
    });
  }); //end register

  // Modify reply link if has-fixed-footer class not exist
  if (!$('html').hasClass('has-fixed-footer')) {
    if ($('.comment-reply-link').length) {
        $('.comment-reply-link').each(function() {
            // Store the original text
            var replyText = $(this).text().trim();

            // Replace the content inside <a> with the custom markup
            $(this).html(`
                <span class="cherito-btn__text">${replyText}</span>
                <span class="cherito-btn__hover cherito-btn__hover--1"></span>
                <span class="cherito-btn__hover cherito-btn__hover--2"></span>
                <span class="cherito-btn__hover cherito-btn__hover--3"></span>
                <span class="cherito-btn__hover cherito-btn__hover--4"></span>
                <span class="cherito-btn__hover cherito-btn__hover--5"></span>
            `);
        });
    }
  }

  $(window).on("resize", function () {
    cherito_stretch();
  });

})(jQuery);
