d83c\uddf9\ud83c\uddf7','Middle East'],['Uganda','\ud83c\uddfa\ud83c\uddec','Africa'],['Ukraine','\ud83c\uddfa\ud83c\udde6','Europe'],['United Arab Emirates','\ud83c\udde6\ud83c\uddea','Middle East'],['United Kingdom','\ud83c\uddec\ud83c\udde7','Europe'],['United States','\ud83c\uddfa\ud83c\uddf8','North America'],['Uruguay','\ud83c\uddfa\ud83c\uddfe','South America'],['Venezuela','\ud83c\uddfb\ud83c\uddea','South America'],['Vietnam','\ud83c\uddfb\ud83c\uddf3','Asia'],['Yemen','\ud83c\uddfe\ud83c\uddea','Middle East'],['Zambia','\ud83c\uddff\ud83c\uddf2','Africa'],['Zimbabwe','\ud83c\uddff\ud83c\uddfc','Africa']\n].map(([name, flag, region]) => ({\n    name,\n    flag,\n    region,\n    crops: 'Mixed Agriculture',\n    farmers: 'Active',\n    season: 'Regional',\n    description: `${name} participates in the global agricultural cycle through regional farming and food systems.`,\n    image: 'https:\/\/images.unsplash.com\/photo-1506744038136-46273834b3fb?q=80&w=1400&auto=format&fit=crop'\n}));\n\nconst baseSteps = [\n  { label: 'Preparation', color: '#92400e' },\n  { label: 'Planting', color: '#166534' },\n  { label: 'Growing', color: '#65a30d' },\n  { label: 'Harvesting', color: '#eab308' },\n  { label: 'Processing', color: '#1d4ed8' },\n  { label: 'Market', color: '#7c3aed' }\n];\n\nconst regionalOffsets = {\n  'Oceania': 3,\n  'Europe': 1,\n  'Africa': 0,\n  'Asia': 2,\n  'North America': 4,\n  'South America': 5,\n  'Middle East': 2\n};\n\nconst countryGrid = document.getElementById('ifuCountryGrid');\nconst searchInput = document.getElementById('ifuSearchInput');\n\nfunction renderTimeline(region) {\n    const timeline = document.getElementById('ifuTimelineSteps');\n    timeline.innerHTML = '';\n\n    const offset = regionalOffsets[region] || 0;\n\n    const rotated = [\n        ...baseSteps.slice(offset),\n        ...baseSteps.slice(0, offset)\n    ];\n\n    rotated.forEach((step, index) => {\n        const stepEl = document.createElement('div');\n        stepEl.className = 'ifu-timeline-step';\n\n        stepEl.innerHTML = `\n            <div class=\"ifu-timeline-icon\" style=\"background:${step.color};\">${index + 1}<\/div>\n            <div style=\"margin-top:12px;font-size:14px;font-weight:700;\">${step.label}<\/div>\n        `;\n\n        timeline.appendChild(stepEl);\n    });\n}\n\nfunction renderCountries(filter = '') {\n    countryGrid.innerHTML = '';\n\n    countries\n    .filter(country => country.name.toLowerCase().includes(filter.toLowerCase()))\n    .forEach((country, index) => {\n\n        const card = document.createElement('div');\n        card.className = `ifu-country-card ifu-glass ${index === 0 ? 'ifu-active-country' : ''}`;\n\n        card.style.borderRadius = '24px';\n        card.style.padding = '20px';\n        card.style.textAlign = 'center';\n\n        card.innerHTML = `\n            <div style=\"font-size:58px;line-height:1;margin-bottom:12px;font-family:'Apple Color Emoji','Segoe UI Emoji','Noto Color Emoji',sans-serif;\">\n                ${country.flag}\n            <\/div>\n\n            <div style=\"font-weight:800;font-size:18px;color:#111827;\">\n                ${country.name}\n            <\/div>\n\n            <div style=\"font-size:13px;color:#6b7280;margin-top:4px;\">\n                ${country.region}\n            <\/div>\n        `;\n\n        card.addEventListener('click', () => selectCountry(country, card));\n        countryGrid.appendChild(card);\n    });\n}\n\nfunction selectCountry(country, selectedCard) {\n    document.querySelectorAll('.ifu-country-card').forEach(card => {\n        card.classList.remove('ifu-active-country');\n    });\n\n    selectedCard.classList.add('ifu-active-country');\n\n    document.getElementById('ifuCountryName').textContent = country.name;\n    document.getElementById('ifuCountryDescription').textContent = country.description;\n    document.getElementById('ifuMainCrops').textContent = country.crops;\n    document.getElementById('ifuFarmers').textContent = country.farmers;\n    document.getElementById('ifuSeason').textContent = country.season;\n    document.getElementById('ifuCountryHero').style.backgroundImage = `url('${country.image}')`;\n\n    renderTimeline(country.region);\n}\n\nsearchInput.addEventListener('input', (e) => {\n    renderCountries(e.target.value);\n});\n\ndocument.getElementById('ifuScrollLeft').addEventListener('click', () => {\n    countryGrid.scrollBy({ left: -500, behavior: 'smooth' });\n});\n\ndocument.getElementById('ifuScrollRight').addEventListener('click', () => {\n    countryGrid.scrollBy({ left: 500, behavior: 'smooth' });\n});\n\nrenderCountries();\nrenderTimeline('Africa');\n<\/script>\n\n<\/div>\n\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-80fc932 e-flex e-con-boxed e-con e-parent\" data-id=\"80fc932\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t\t\t<div class=\"elementor-element elementor-element-cf5cb4f elementor-widget elementor-widget-heading\" data-id=\"cf5cb4f\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Agricultural Closed Loop System\n<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-32636eb elementor-widget elementor-widget-text-editor\" data-id=\"32636eb\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\t<p style=\"text-align: center;\"><strong><span style=\"font-size: 21px;\">From Production To Impact. One World One Cycle<\/span><\/strong><\/p><p>\u00a0<\/p><p class=\"x_402487250isSelectedEnd\">IFU\u2019s Agricultural Closed Loop System connects every stage of the agricultural journey into one integrated global ecosystem\u2014from soil preparation and production to trade, education, funding, sustainability, and community impact.<\/p><p>\u00a0<\/p><p class=\"x_402487250isSelectedEnd\">By linking farmers, markets, technology, intelligence, and rural development into a continuous cycle, IFU transforms agriculture from isolated activities into a connected system designed to strengthen food security, increase opportunity, reduce waste, and create long-term global impact. This is more than agriculture, It is a unified system where production creates opportunity, opportunity creates growth, and growth creates lasting impact for communities worldwide.<\/p><div>\u00a0<\/div><div>One Platform.<\/div><div>One Closed Loop System. One World One Cycle.<\/div><div>One Shared Global Mission.<\/div><p style=\"text-align: left;\">\u00a0<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-0a9369f elementor-widget elementor-widget-shortcode\" data-id=\"0a9369f\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"shortcode.default\">\n\t\t\t\t\t\t\t<div class=\"elementor-shortcode\">\r\n<style>\r\n\r\n\/* =====================================================\r\nGLOBAL\r\n===================================================== *\/\r\n\r\n.ifu-wrapper-closed-loop,\r\n.ifu-wrapper-closed-loop *{\r\n    box-sizing:border-box;\r\n    font-family:Arial, Helvetica, sans-serif;\r\n}\r\n\r\n.ifu-wrapper-closed-loop{\r\n    width:100%;\r\n    background:#ffffff;\r\n    padding:40px 0 80px;\r\n    overflow:hidden;\r\n}\r\n\r\n\/* =====================================================\r\nCIRCLE SYSTEM\r\n===================================================== *\/\r\n\r\n.ifu-system-closed-loop{\r\n    position:relative;\r\n    width:780px;\r\n    height:780px;\r\n    margin:0 auto;\r\n}\r\n\r\n\/* FLOW *\/\r\n\r\n.flow-closed-loop{\r\n    position:absolute;\r\n    inset:0;\r\n    width:100%;\r\n    height:100%;\r\n    z-index:1;\r\n    pointer-events:none;\r\n}\r\n\r\n.arrow-closed-loop{\r\n    fill:none;\r\n    stroke-width: